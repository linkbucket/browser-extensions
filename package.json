{
  "name": "linkbucket-browser-extension",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "description": "Save the current page directly into your Linkbucket account.",
  "homepage": "https://linkbucket.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/linkbucketapp/browser-extensions.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "./scripts/build.sh",
    "build:chrome": "./scripts/build.sh chrome",
    "build:firefox": "./scripts/build.sh firefox",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "test": "vitest run",
    "lint:ext": "npm run build:firefox && addons-linter dist/firefox"
  },
  "dependencies": {
    "tom-select": "^2.4.3",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5",
    "web-ext": "^10.1.0"
  }
}
